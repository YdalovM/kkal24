# === Обязательно на проде ===
# Публичный URL сайта (HTTPS, без слэша в конце). Canonical, Open Graph, sitemap, JSON-LD.
# Должен совпадать с тем, что в браузере (с www или без — как настроите в DNS/ nginx).
NEXT_PUBLIC_SITE_URL=https://ваш-домен.ru

# Порт процесса Node (если хостинг не задаёт сам). Nginx проксирует на этот порт.
# PORT=3000

# === Опционально ===
# Яндекс.Вебмастер — значение content из <meta name="yandex-verification" …> (если не задано, в сборке подставляется актуальный код из репозитория).
# NEXT_PUBLIC_YANDEX_VERIFICATION=

# Google Search Console — значение из meta google-site-verification
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Яндекс.Метрика: опционально переопределить номер счётчика. Если не задано, в бандл подставляется
# `YANDEX_METRIKA_COUNTER_ID_DEFAULT` из `lib/yandex-metrika-counter.ts` (kkal24.ru).
# NEXT_PUBLIC_YM_COUNTER_ID=108521872

# Реклама: сайт собирается как статика (`output: "export"`). Строки ads.txt — в файле `public/ads.txt`, затем `npm run build`.
